# Copy this file to .env and fill in your keys
# cp .env.example .env

# YouTube Data API v3 (FREE — get one at https://console.cloud.google.com/apis)
# Enable "YouTube Data API v3", then create an API key under Credentials
YOUTUBE_API_KEY=

# RapidAPI Key (for TikTok scraper — https://rapidapi.com)
# Subscribe to "TikTok Scraper" (tiktok-scraper7) on RapidAPI
RAPIDAPI_KEY=

# Instagram does NOT need an API key — it uses Instagram's public web API directly

# Server port (default: 3000)
PORT=3000
